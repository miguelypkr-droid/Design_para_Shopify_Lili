<section class="lip-section">
  <div class="lip-card">

    <!-- CIRCULO IMAGEN (INTERSECTA) -->
    <div class="lip-circle">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: '600x600' }}" alt="Imagen" />
      {% endif %}
    </div>

    <!-- TEXTO -->
    <div class="lip-content">
      <h2 class="lip-title">
        {{ section.settings.title }}
      </h2>

      <div class="lip-text">
        {{ section.settings.text }}
      </div>
    </div>

  </div>
</section>

<style>
.lip-section{
  background: #f3f3f3;
  padding: 80px 20px;
}

/* TARJETA RECTANGULAR */
.lip-card{
  max-width: 1100px;
  margin: auto;
  background: white;
  padding: 60px 60px 60px 140px;
  position: relative;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.08);
  overflow: visible;
}

/* CIRCULO QUE INTERSECTA */
.lip-circle{
  position: absolute;
  left: -90px;
  top: 50%;
  transform: translateY(-50%);
  width: 220px;
  height: 220px;
  border-radius: 50%;
  border: 10px solid white;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  overflow: hidden;
  background: #ddd;
}

.lip-circle img{
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* TEXTO */
.lip-content{
  max-width: 700px;
}

.lip-title{
  font-size: 26px;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 15px;
  color: #2b2b2b;
}

.lip-text{
  font-size: 16px;
  line-height: 1.7;
  color: #555;
}

/* RESPONSIVE */
@media(max-width: 768px){
  .lip-card{
    padding: 40px 20px 40px 20px;
    text-align: center;
  }

  .lip-circle{
    position: relative;
    left: auto;
    top: auto;
    transform: none;
    margin: -100px auto 20px auto;
  }
}
</style>

{% schema %}
{
  "name": "Lip Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Aumento y Perfilamiento Labial"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Escribe aquí la descripción del servicio...</p>"
    }
  ],
  "presets": [
    {
      "name": "Lip Section"
    }
  ]
}
{% endschema %}